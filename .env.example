# ============================================================
# PQC-QKD Hybrid PoC — Sample environment file
# Copy to `.env` and adjust as needed. Never commit `.env`.
# ============================================================

# ----- Docker Compose -----
COMPOSE_PROJECT_NAME=pqcqkd

# ----- Arnika (per-node; alice/bob entrypoints read these) -----
# Operational mode. See submodules/arnika-vq/config/config.go:39-45
# Values: QkdAndPqcRequired | AtLeastQkdRequired | AtLeastPqcRequired | EitherQkdOrPqcRequired
ARNIKA_MODE=QkdAndPqcRequired

# Key rotation interval (default in paper: 120s; use 30s for demo)
ARNIKA_INTERVAL=30s

# KMS HTTP timeout / retry
KMS_HTTP_TIMEOUT=10s
KMS_BACKOFF_MAX_RETRIES=5
KMS_BACKOFF_BASE_DELAY=200ms
KMS_RETRY_INTERVAL=10s

# PQC PSK file path (inside container). Rosenpass writes here.
PQC_PSK_FILE=/var/lib/rosenpass/pqc.psk

# ----- BB84-KME -----
# Photon batch size per BB84 round (raises key generation rate; CPU-bound)
BB84_BATCH=2048
# Channel depolarizing probability (0.0 = perfect, 0.02 = realistic fiber)
BB84_CHANNEL_NOISE=0.01
# Reconciliation QBER abort threshold (Cascade aborts above this)
BB84_QBER_THRESHOLD=0.11
# Key pool target / max
BB84_POOL_LOW=8
BB84_POOL_MAX=64
# Eve attack defaults (controllable via WebUI / POST /sim/eve)
BB84_EVE_ENABLED=false
BB84_EVE_PROB=0.0

# ----- WebUI -----
WEBUI_BACKEND_PORT=8000
WEBUI_FRONTEND_PORT=5173

# ----- WireGuard internal addressing -----
WG_SUBNET=10.0.0.0/24
WG_ALICE_IP=10.0.0.1
WG_BOB_IP=10.0.0.2
WG_CHARLIE_IP=10.0.0.3
WG_LISTEN_PORT_ALICE=51820
WG_LISTEN_PORT_BOB=51821

# ----- mTLS for ETSI-014 (disabled by default; Phase 7) -----
ETSI_MTLS_ENABLED=false
