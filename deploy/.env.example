# ============================================================
# Cloud deployment environment (ConoHa VPS + Value Domain).
# Copy to `.env` at the repo root before running deploy/deploy.sh:
#     cp deploy/.env.example .env
# Never commit the filled-in `.env`.
# ============================================================

# ----- Public entry point (Caddy auto-TLS) -----
# Your Value-Domain domain pointed (A record) at the ConoHa VPS public IP.
PUBLIC_HOST=qkd.example.com
# Contact e-mail for Let's Encrypt.
ACME_EMAIL=admin@example.com

# Keep the WebUI bound to loopback on the host — only Caddy is public.
# (Caddy reaches these over the internal docker network by service name.)
WEBUI_FRONTEND_PORT=127.0.0.1:5173
WEBUI_BACKEND_PORT=127.0.0.1:8000

# ----- BB84 physics backend (license-aware) -----
# Distributable / client-delivery profile defaults to the fully-permissive
# Strawberry Fields backend (Apache-2.0). For SaaS you may opt into others:
#   qutip (BSD-3) | simqn (GPL-3.0) | sequence (custom Argonne, BSD-3-equiv)
#   | cvqkd (Strawberry Fields, Apache-2.0) | composite | qkdnetsim_proxy
SIMULATOR_BACKEND=cvqkd

# ----- Arnika (QKD‖PQC hybrid) -----
ARNIKA_MODE=QkdAndPqcRequired
ARNIKA_INTERVAL=30s

# ----- Rosenpass (real post-quantum exchange; container-internal UDP) -----
RP_LISTEN_PORT=9997

# ----- BB84-KME tuning -----
BB84_BATCH=2048
BB84_CHANNEL_NOISE=0.01
BB84_QBER_THRESHOLD=0.11
BB84_POOL_LOW=8
BB84_POOL_MAX=64

# ----- WireGuard internal addressing (not published publicly) -----
WG_ALICE_IP=10.0.0.1
WG_BOB_IP=10.0.0.2
WG_LISTEN_PORT_ALICE=51820
WG_LISTEN_PORT_BOB=51821
