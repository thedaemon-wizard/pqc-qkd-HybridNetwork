# =====================================================================
# OpenSSL 3.4 + oqs-provider PQC TLS demo (algorithm agility lane).
#
# Crypto agility lane: maintains the broadest possible NIST PQC algorithm
# space — ML-KEM/ML-DSA/SLH-DSA/Falcon/HQC/Classic McEliece — plus future
# NIST round 4 candidates via the provider plugin mechanism.
#
# Standards reference: RFC 7696 (Cryptographic Algorithm Agility),
#                      NIST SP 800-131A Rev.3.
# =====================================================================
FROM debian:bookworm-slim AS oqs-builder

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates git cmake ninja-build gcc g++ libssl-dev pkg-config && \
    rm -rf /var/lib/apt/lists/*

COPY submodules/liboqs /src/liboqs
WORKDIR /src/liboqs
RUN cmake -S . -B build -GNinja \
        -DCMAKE_INSTALL_PREFIX=/opt/oqs \
        -DBUILD_SHARED_LIBS=ON -DOQS_USE_OPENSSL=ON && \
    cmake --build build --parallel && cmake --install build

COPY submodules/oqs-provider /src/oqs-provider
WORKDIR /src/oqs-provider
RUN cmake -S . -B build -GNinja \
        -DCMAKE_PREFIX_PATH=/opt/oqs \
        -DCMAKE_INSTALL_PREFIX=/opt/oqs && \
    cmake --build build --parallel && cmake --install build

# ---------- runtime ----------
FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
        openssl libssl3 ca-certificates curl iproute2 jq && \
    rm -rf /var/lib/apt/lists/*

COPY --from=oqs-builder /opt/oqs /opt/oqs
ENV OPENSSL_MODULES=/opt/oqs/lib64/ossl-modules:/opt/oqs/lib/ossl-modules
ENV LD_LIBRARY_PATH=/opt/oqs/lib:/opt/oqs/lib64

# Self-signed cert
RUN openssl req -x509 -newkey rsa:2048 -keyout /etc/ssl/private/server.key \
        -out /etc/ssl/certs/server.crt -days 365 -nodes \
        -subj "/CN=tls-oqs.pqcqkd.local" -batch

EXPOSE 4433

# Algorithm agility lane: includes both NIST standards and experimental
# algorithms (HQC, Falcon, SLH-DSA variants, etc.)
ENV TLS_GROUPS="X25519MLKEM768:p384_kyber768:mlkem768:hqc128:frodo640aes"

CMD ["sh", "-c", "OPENSSL_MODULES=${OPENSSL_MODULES} \
                  openssl s_server -tls1_3 -provider default -provider oqsprovider \
                                   -groups ${TLS_GROUPS} \
                                   -accept 0.0.0.0:4433 \
                                   -cert /etc/ssl/certs/server.crt \
                                   -key /etc/ssl/private/server.key \
                                   -www"]
